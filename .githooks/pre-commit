#!/bin/bash
# pre-commit hook: verify working tree state for BMAD->GSD->GIT pipeline

echo "🔍 Pre-commit: verificando pipeline BMAD->GSD->GIT..."

# Check if there are any staged files
if git diff --cached --quiet; then
    echo "⚠  Nada staged para commit"
    exit 0
fi

# Warn if too many files changed without a plan
STAGED_COUNT=$(git diff --cached --name-only | wc -l)
if [ "$STAGED_COUNT" -gt 50 ]; then
    echo "⚠  Muitos arquivos ($STAGED_COUNT) em um unico commit"
    echo "   Pipeline pede commits atomicos"
    echo "   Considere split com git add -p"
    echo ""
fi

echo "✓  Pre-commit ok"
exit 0
