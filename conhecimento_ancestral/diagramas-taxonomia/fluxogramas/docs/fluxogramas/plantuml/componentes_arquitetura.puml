  [LocatorCandidateCollector] as LocatorCandidateCollector
  [VisualContextCollector] as VisualContextCollector
  [StorageCollector] as StorageCollector
  [SensitiveDataGuard] as SensitiveDataGuard
  [EvidenceRepository] as EvidenceRepository
}

package "6. Camada de sessão e normalização" as P6 {
  [SessionSerializer] as SessionSerializer
  [SessionParser] as SessionParser
  [StepNormalizer] as StepNormalizer
  [StepMerger] as StepMerger
  [RecordingValidator] as RecordingValidator
  [CanonicalStepModel] as CanonicalStepModel
}

package "7. Camada de geração" as P7 {
  [ScriptGenerator] as ScriptGenerator
  [PlaywrightTemplateRenderer] as PlaywrightTemplateRenderer
  [LocatorStrategyBuilder] as LocatorStrategyBuilder
  [WaitStrategyBuilder] as WaitStrategyBuilder
  [ScriptMetadataGenerator] as ScriptMetadataGenerator
}

package "8. Camada de execução diagnóstica" as P8 {
  [ExecutorAgent] as ExecutorAgent
  [ExecutionCollector] as ExecutionCollector
  [FailureDiagnostic] as FailureDiagnostic
  [FailureSignatureBuilder] as FailureSignatureBuilder
  [RunRepository] as RunRepository
}

package "9. Camada multiagente" as P9 {
  [AgentOrchestrator] as AgentOrchestrator
  [FailureClassifier] as FailureClassifier
  [SelectorRepairAgent] as SelectorRepairAgent
  [TimingAsyncAgent] as TimingAsyncAgent
  [ContextScopeAgent] as ContextScopeAgent
  [StateRecoveryAgent] as StateRecoveryAgent
  [DynamicDOMAgent] as DynamicDOMAgent
  [SpecialInteractionAgent] as SpecialInteractionAgent
  [GeneralDiagnosticAgent] as GeneralDiagnosticAgent
  [LLMFallbackAgent] as LLMFallbackAgent
}

package "10. Camada de controle de patch" as P10 {
  [PatchGenerator] as PatchGenerator
  [PatchValidator] as PatchValidator
  [ProgressDetector] as ProgressDetector
  [RollbackManager] as RollbackManager
  [VersionManager] as VersionManager
  [AttemptHistoryRepository] as AttemptHistoryRepository
}

package "11. Camada de estabilização" as P11 {
  [DeterministicSelfHealingAgent] as DeterministicSelfHealingAgent
  [DataSeparationAgent] as DataSeparationAgent
  [PerformanceOptimizerAgent] as PerformanceOptimizerAgent
  [LocatorRegistry] as LocatorRegistry
  [HealingRuleRegistry] as HealingRuleRegistry
}

package "12. Conhecimento e entrega" as P12 {
  [KnowledgeBase] as KnowledgeBase
  [FailurePatternRepository] as FailurePatternRepository
  [HealingRuleRepository] as HealingRuleRepository
  [FinalArtifactBuilder] as FinalArtifactBuilder
  [ReportGenerator] as ReportGenerator
}

package "13. Configuração [Feature 006]" as P-Config {
  [ConfigLoader] as ConfigLoader
  [TestForgeConfig] as TestForgeConfig
}

package "14. Validação de implementação [Feature 006]" as P-Validation {
  [ImplementationAuditor] as ImplementationAuditor
}

package "15. Orquestração LangGraph [Feature 006]" as P-LangGraph {
  [LangGraphWorkflow] as LangGraphWorkflow
  [CurationOrchestrator] as CurationOrchestrator
  LangGraphWorkflow --> CurationOrchestrator : encapsula fluxo de 14 nós
}

database "output/{slug}/recording" as RecordingArtifacts {
  [session_raw.json] as SessionRaw
  [session_normalized.json] as SessionNormalized
  [fingerprint_initial.json] as FingerprintInitial
  [fingerprint_final.json] as FingerprintFinal
  [recording_summary.md] as RecordingSummary
  [sensitive_data_report.json] as SensitiveDataReport
}

database "output/{slug}/evidence" as EvidenceArtifacts {
  [screenshots/] as EvidenceScreenshots
  [dom/] as EvidenceDOM
  [network/] as EvidenceNetwork
  [console/] as EvidenceConsole
  [storage/] as EvidenceStorage
  [frames/] as EvidenceFrames
  [selectors/] as EvidenceSelectors
  [components/] as EvidenceComponents
}

database "output/{slug}/generated" as GeneratedArtifacts {
  [script_v0.py] as ScriptV0
  [script_metadata.json] as ScriptMetadata
  [steps_normalized.json] as StepsNormalized
  [selector_candidates.json] as SelectorCandidates
}

database "output/{slug}/runs/run_N" as RunArtifacts {
  [execution.json] as ExecutionJson
  [failure_signature.json] as FailureSignatureJson
  [trace.zip] as TraceZip
  [screenshot_failure.png] as ScreenshotFailure
  [dom_failure.html] as DOMFailure
  [console_network.json] as ConsoleNetwork
}

database "output/{slug}/agents" as AgentArtifacts {
  [selector_repair/] as AgentSelectorRepair
  [timing_async/] as AgentTimingAsync
  [context_scope/] as AgentContextScope
  [state_recovery/] as AgentStateRecovery
  [dynamic_dom/] as AgentDynamicDOM
  [special_interaction/] as AgentSpecialInteraction
  [llm_fallback/] as AgentLLMFallback
}

database "output/{slug}/knowledge" as KnowledgeArtifacts {
  [failure_signatures.jsonl] as FailureSignaturesJsonl
  [resolved_patterns.jsonl] as ResolvedPatternsJsonl
  [healing_rules.json] as KnowledgeHealingRules
}

database "output/{slug}/final" as FinalArtifacts {
  [script_final.py] as ScriptFinal
  [test_data.json] as TestData
  [locators.json] as LocatorsJson
  [healing_rules.json] as FinalHealingRules
  [execution_report.json] as ExecutionReport
  [agent_history.json] as AgentHistory
  [fingerprint_summary.json] as FingerprintSummary
}

CLIRecord --> InputValidator : valida parâmetros
CLIRecord --> SettingsLoader : carrega configurações
CLIRecord --> WorkspaceManager : cria workspace
SettingsLoader --> WorkspaceManager : fornece políticas e paths
InputValidator --> WorkspaceManager : autoriza criação
WorkspaceManager --> RecordingArtifacts : cria estrutura
WorkspaceManager --> EvidenceArtifacts : cria estrutura
WorkspaceManager --> GeneratedArtifacts : cria estrutura
WorkspaceManager --> RunArtifacts : cria estrutura
WorkspaceManager --> AgentArtifacts : cria estrutura
WorkspaceManager --> KnowledgeArtifacts : cria estrutura
WorkspaceManager --> FinalArtifacts : cria estrutura

BrowserContextManager --> PlaywrightAdapter : controla browser/context/page
BrowserContextManager --> TraceManager : ativa tracing
BrowserContextManager --> ScreenshotManager : ativa screenshots
BrowserContextManager --> EventListener : registra listeners nativos
EventListener --> NetworkObserver : request/response
EventListener --> ConsoleObserver : console/pageerror
EventListener --> FrameObserver : frameattached/framenavigated
EventListener --> DialogObserver : dialog/popup
TraceManager --> TraceZip : persiste trace
ScreenshotManager --> EvidenceScreenshots : persiste screenshots
NetworkObserver --> EvidenceNetwork : persiste rede
ConsoleObserver --> EvidenceConsole : persiste console
FrameObserver --> EvidenceFrames : persiste frames

FingerprintEngine --> TechnologyDetector : solicita detecção tecnológica
TechnologyDetector --> JSFPrimeFacesDetector : detecta JSF/PrimeFaces
TechnologyDetector --> JQueryDetector : detecta jQuery/jQuery UI
TechnologyDetector --> AngularDetector : detecta Angular
TechnologyDetector --> LegacyJSPDetector : detecta JSP legado
TechnologyDetector --> IonicCordovaDetector : detecta Ionic/Cordova
FingerprintEngine --> ComponentCataloger : cataloga componentes ricos
FingerprintEngine --> DynamicIdDetector : identifica IDs dinâmicos
FingerprintEngine --> FrameShadowScanner : mapeia frames e shadow DOM
FingerprintEngine --> FingerprintInitial : salva fingerprint inicial
FingerprintEngine --> FingerprintFinal : salva fingerprint final
ComponentCataloger --> EvidenceComponents : persiste catálogo
FrameShadowScanner --> EvidenceFrames : persiste escopos

SmartRecorder --> JSInjector : injeta recorder JS
SmartRecorder --> RecorderOverlay : injeta overlay
SmartRecorder --> MutationObserverBridge : observa mutações
SmartRecorder --> DOMEventCollector : coleta eventos DOM
SmartRecorder --> AssertHintCollector : coleta assert hints
SmartRecorder --> CheckpointCollector : coleta checkpoints
JSInjector --> PlaywrightAdapter : injeta scripts via page/context
RecorderOverlay --> PlaywrightAdapter : injeta interface visual
MutationObserverBridge --> EvidenceDOM : persiste mutações relevantes
DOMEventCollector --> SessionSerializer : envia eventos brutos
AssertHintCollector --> SessionSerializer : envia hints
CheckpointCollector --> SessionSerializer : envia checkpoints

SmartRecorder --> BrowserContextManager : depende do contexto de navegador
SmartRecorder --> EventListener : usa eventos nativos
SmartRecorder --> NetworkObserver : associa sinais de rede
SmartRecorder --> ConsoleObserver : associa sinais de console
SmartRecorder --> FrameObserver : associa contexto de frame
SmartRecorder --> FingerprintEngine : usa fingerprint inicial e incremental
SmartRecorder --> TechnologyDetector : ajusta coleta por tecnologia
SmartRecorder --> FrameShadowScanner : usa escopo frame/shadow
SmartRecorder --> EvidenceCollector : solicita coleta enriquecida
SmartRecorder --> LocatorCandidateCollector : coleta locators alternativos
SmartRecorder --> SensitiveDataGuard : aplica política de mascaramento

EvidenceCollector --> DOMSnapshotCollector : coleta DOM
EvidenceCollector --> LocatorCandidateCollector : coleta candidatos de locator
EvidenceCollector --> VisualContextCollector : coleta screenshot/contexto visual
EvidenceCollector --> StorageCollector : coleta storage/cookies
EvidenceCollector --> SensitiveDataGuard : mascara dados sensíveis
EvidenceCollector --> EvidenceRepository : persiste pacote de evidências
DOMSnapshotCollector --> EvidenceDOM : persiste snapshots
LocatorCandidateCollector --> EvidenceSelectors : persiste candidatos
VisualContextCollector --> EvidenceScreenshots : persiste contexto visual
StorageCollector --> EvidenceStorage : persiste estado
SensitiveDataGuard --> SensitiveDataReport : registra mascaramento
EvidenceRepository --> EvidenceArtifacts : organiza evidências

SessionSerializer --> SessionRaw : salva eventos brutos
SessionSerializer --> RecordingSummary : atualiza resumo
SessionParser --> SessionRaw : lê sessão bruta
RecordingValidator --> SessionRaw : valida integridade
RecordingValidator --> FingerprintInitial : valida baseline
RecordingValidator --> FingerprintFinal : valida fechamento
StepNormalizer --> SessionParser : consome eventos parseados
StepNormalizer --> StepMerger : agrupa eventos redundantes
StepNormalizer --> CanonicalStepModel : produz steps canônicos
StepMerger --> CanonicalStepModel : consolida intenção
StepNormalizer --> SessionNormalized : salva sessão normalizada
StepNormalizer --> StepsNormalized : salva steps normalizados
LocatorCandidateCollector --> SelectorCandidates : salva candidatos

ScriptGenerator --> SessionParser : lê sessão
ScriptGenerator --> StepNormalizer : usa steps canônicos
ScriptGenerator --> LocatorStrategyBuilder : constrói estratégia de locators
ScriptGenerator --> WaitStrategyBuilder : constrói esperas observáveis
ScriptGenerator --> PlaywrightTemplateRenderer : renderiza Playwright Python
ScriptGenerator --> ScriptMetadataGenerator : gera metadados
LocatorStrategyBuilder --> SelectorCandidates : consome locators candidatos
WaitStrategyBuilder --> EvidenceNetwork : usa hints de rede
WaitStrategyBuilder --> EvidenceDOM : usa hints de DOM
ScriptMetadataGenerator --> ScriptMetadata : salva metadados
PlaywrightTemplateRenderer --> ScriptV0 : gera script bruto
ScriptGenerator --> ScriptV0 : publica script_v0.py

ExecutorAgent --> ScriptV0 : executa script bruto
ExecutorAgent --> PlaywrightAdapter : executa via Playwright
ExecutorAgent --> ExecutionCollector : coleta execução
ExecutionCollector --> RunRepository : persiste run_N
ExecutionCollector --> ExecutionJson : salva resultado
ExecutionCollector --> TraceZip : salva trace
ExecutionCollector --> ScreenshotFailure : salva screenshot de falha
ExecutionCollector --> DOMFailure : salva DOM de falha
ExecutionCollector --> ConsoleNetwork : salva console/rede
ExecutorAgent --> FailureDiagnostic : alimenta diagnóstico quando falha
FailureDiagnostic --> FailureSignatureBuilder : constrói assinatura
FailureSignatureBuilder --> FailureSignatureJson : salva assinatura
ExecutorAgent --> FailureDiagnostic : envia evidências da falha
ExecutorAgent --> FailureClassifier : envia status e assinatura preliminar
FailureDiagnostic --> FailureClassifier : fornece failure_signature

FailureClassifier --> AgentOrchestrator : classifica família da falha
AgentOrchestrator --> SelectorRepairAgent : roteia seletores frágeis
AgentOrchestrator --> TimingAsyncAgent : roteia timing/assincronismo
AgentOrchestrator --> ContextScopeAgent : roteia contexto/escopo
AgentOrchestrator --> StateRecoveryAgent : roteia estado da aplicação
AgentOrchestrator --> DynamicDOMAgent : roteia DOM dinâmico
AgentOrchestrator --> SpecialInteractionAgent : roteia interação especializada
AgentOrchestrator --> GeneralDiagnosticAgent : roteia falha não classificada
AgentOrchestrator --> LLMFallbackAgent : fallback controlado somente após estratégias determinísticas
SelectorRepairAgent --> PatchGenerator : propõe correção de locator
TimingAsyncAgent --> PatchGenerator : propõe wait/retry determinístico
ContextScopeAgent --> PatchGenerator : propõe frame/shadow/context reacquire
StateRecoveryAgent --> PatchGenerator : propõe recuperação de estado
DynamicDOMAgent --> PatchGenerator : propõe estabilização de DOM
SpecialInteractionAgent --> PatchGenerator : propõe interação especializada
GeneralDiagnosticAgent --> PatchGenerator : propõe diagnóstico geral
LLMFallbackAgent --> PatchGenerator : propõe patch candidato controlado

note right of LLMFallbackAgent
  O LLM não é primeira opção.
  Ele atua apenas como fallback controlado,
  após estratégias determinísticas aplicáveis.
  Toda saída precisa passar pelo PatchValidator.
end note

PatchGenerator --> PatchValidator : envia patch candidato
PatchValidator --> VersionManager : cria versão temporária se válido
VersionManager --> ExecutorAgent : executa versão temporária
ExecutorAgent --> ProgressDetector : envia resultado comparativo
ProgressDetector --> AttemptHistoryRepository : registra tentativa
ProgressDetector --> RunRepository : consulta execuções anteriores
ProgressDetector --> FailureDiagnostic : compara assinaturas
ProgressDetector --> FailureClassifier : solicita reclassificação quando necessário
ProgressDetector --> RollbackManager : aciona rollback em regressão
RollbackManager --> VersionManager : restaura versão anterior
AttemptHistoryRepository --> AgentArtifacts : persiste histórico por agente
ProgressDetector --> PatchValidator : aceita patch se PASSED_STEP ou PROGRESSED
ProgressDetector --> RollbackManager : rollback se REGRESSED
ProgressDetector --> FailureClassifier : reclassifica se ERROR_CHANGED
ProgressDetector --> AgentOrchestrator : solicita nova tentativa se STAGNATED ou UNRESOLVED

note right of ProgressDetector
  Estados de progresso:
  - PASSED_STEP
  - PROGRESSED
  - STAGNATED
  - REGRESSED
  - ERROR_CHANGED
  - UNRESOLVED

  A decisão controla aceitar patch,
  fazer rollback ou reclassificar.
end note

DeterministicSelfHealingAgent --> AttemptHistoryRepository : consolida patches aceitos
DeterministicSelfHealingAgent --> LocatorRegistry : registra locators finais
DeterministicSelfHealingAgent --> HealingRuleRegistry : registra regras determinísticas
DeterministicSelfHealingAgent --> PatchValidator : valida regras finais
DeterministicSelfHealingAgent --> VersionManager : consolida script curado
DataSeparationAgent --> SessionNormalized : extrai dados variáveis
DataSeparationAgent --> TestData : gera massa de teste separada
DataSeparationAgent --> ScriptFinal : parametriza script final
PerformanceOptimizerAgent --> ExecutorAgent : executa rodadas limpas
PerformanceOptimizerAgent --> ExecutionCollector : mede estabilidade/performance
PerformanceOptimizerAgent --> DeterministicSelfHealingAgent : sugere otimizações determinísticas
LocatorRegistry --> LocatorsJson : salva locators finais
HealingRuleRegistry --> FinalHealingRules : salva regras finais
HealingRuleRegistry --> KnowledgeHealingRules : sincroniza regras globais

KnowledgeBase --> FailurePatternRepository : consulta padrões de falha
KnowledgeBase --> HealingRuleRepository : consulta regras de healing
FailurePatternRepository --> FailureSignaturesJsonl : persiste assinaturas
FailurePatternRepository --> ResolvedPatternsJsonl : persiste padrões resolvidos
HealingRuleRepository --> KnowledgeHealingRules : persiste regras
FailureDiagnostic --> KnowledgeBase : envia nova assinatura
ProgressDetector --> KnowledgeBase : envia resultado da tentativa
AgentOrchestrator --> KnowledgeBase : consulta histórico para roteamento
SelectorRepairAgent --> KnowledgeBase : consulta padrões resolvidos
TimingAsyncAgent --> KnowledgeBase : consulta padrões resolvidos
ContextScopeAgent --> KnowledgeBase : consulta padrões resolvidos
StateRecoveryAgent --> KnowledgeBase : consulta padrões resolvidos
DynamicDOMAgent --> KnowledgeBase : consulta padrões resolvidos
SpecialInteractionAgent --> KnowledgeBase : consulta padrões resolvidos
GeneralDiagnosticAgent --> KnowledgeBase : consulta padrões resolvidos
KnowledgeBase --> AgentOrchestrator : fornece histórico para seleção de agente
KnowledgeBase --> DeterministicSelfHealingAgent : fornece regras consolidadas
KnowledgeBase --> HealingRuleRegistry : fornece regras conhecidas

FinalArtifactBuilder --> ScriptFinal : publica script final
FinalArtifactBuilder --> TestData : publica massa separada
FinalArtifactBuilder --> LocatorsJson : publica locators
FinalArtifactBuilder --> FinalHealingRules : publica healing rules
FinalArtifactBuilder --> ExecutionReport : publica relatório de execução
FinalArtifactBuilder --> AgentHistory : publica histórico dos agentes
FinalArtifactBuilder --> FingerprintSummary : publica resumo de fingerprint
ReportGenerator --> RecordingSummary : usa resumo da gravação
ReportGenerator --> ExecutionReport : gera relatório final
ReportGenerator --> AgentHistory : gera histórico rastreável
ReportGenerator --> FingerprintSummary : gera resumo técnico

CLIRecord --> BrowserContextManager : inicia sessão validada
BrowserContextManager --> FingerprintEngine : fornece página inicial
FingerprintEngine --> SmartRecorder : fornece fingerprint e tecnologia
SmartRecorder --> SessionSerializer : produz sessão bruta
SmartRecorder --> EvidenceCollector : produz evidências enriquecidas
SessionSerializer --> RecordingValidator : encaminha gravação
RecordingValidator --> StepNormalizer : libera normalização
StepNormalizer --> ScriptGenerator : fornece steps canônicos
ScriptGenerator --> ExecutorAgent : fornece script_v0
ExecutorAgent --> FailureDiagnostic : se falhar
FailureClassifier --> AgentOrchestrator : roteia correção
AgentOrchestrator --> PatchGenerator : coordena proposta
PatchValidator --> ProgressDetector : valida evolução
ProgressDetector --> DeterministicSelfHealingAgent : entrega patches aceitos
DeterministicSelfHealingAgent --> DataSeparationAgent : entrega script curado
DataSeparationAgent --> PerformanceOptimizerAgent : entrega script parametrizado
PerformanceOptimizerAgent --> FinalArtifactBuilder : entrega versão estabilizada
FinalArtifactBuilder --> ReportGenerator : consolida entrega

note bottom of SmartRecorder
  SmartRecorder não grava apenas ações.
  Ele coordena contexto técnico, evidência,
  fingerprint, locators alternativos,
  sinais de rede, DOM, console, frame,
  shadow DOM e estado da aplicação.
end note

note bottom of ScriptGenerator
  ScriptGenerator depende de:
  - SessionParser
  - StepNormalizer
  - LocatorStrategyBuilder
  - WaitStrategyBuilder

  O script_v0.py é diagnóstico,
  não é o artefato final.
end note

note bottom of DeterministicSelfHealingAgent
  O self-healing final deve ser:
  - determinístico
  - rastreável
  - validado por execução
  - reversível via rollback
  - baseado nas evidências da gravação
end note

note bottom of KnowledgeBase
  KnowledgeBase recebe:
  - assinaturas de falha
  - padrões resolvidos
  - regras de healing

  E fornece histórico para:
  - agentes especializados
  - orquestração
  - estabilização determinística
end note

ConfigLoader --> TestForgeConfig : instancia e valida
ConfigLoader --> SettingsLoader : substitui/complementa carregamento
LangGraphWorkflow --> CurationOrchestrator : coordena via StateGraph 14 nós
LangGraphWorkflow --> AgentOrchestrator : nó curate_failures delega para multiagentes
ImplementationAuditor --> CurationOrchestrator : valida implementação antes de executar

' ============================================================
' BUG-020: Componentes adicionados em BUG-007–BUG-014
' ============================================================

package "P-Debug: src/testforge/debug/" as P_Debug {
  [DebugLogger] as DebugLogger
  note right of DebugLogger
    Singleton. configure(slug, output_dir, debug_mode).
    event(name, payload) → stderr + debug/debug.log.
    Sanitiza campos sensíveis (password/token/api_key/secret).
    Ativado por recording.debug_mode=True / --debug CLI.
  end note
}

package "P-Recording-BUG018: Recorder + RecorderOverlay (atualizado)" as P_RecBug018 {
  [Recorder] as Recorder
  note right of Recorder
    BrowserConfig.navigation_timeout_ms (padrão 60000 ms).
    Recorder.finish() verifica page.is_closed() antes de
    chamar FingerprintCollector.collect_final() — BUG-019.
    BrowserManager.close() envolvido em try/except — BUG-019.
    ScreenshotCollector.capture_screenshot() e
    DOMSnapshotCollector.capture_dom_snapshot() verificam
    page.is_closed() + try/except antes de chamar API
    Playwright — BUG-021.
  end note
  [RecorderOverlay_BUG018] as RecorderOverlay_BUG018
  note right of RecorderOverlay_BUG018
    OVERLAY_JS usa window.__tfRecordingActive (+ sessionStorage)
    para persistir estado entre full-page navigations — BUG-018.
    updateUI() chamado ao final da inicialização da IIFE para
    sincronizar statusEl.textContent com state restaurado — BUG-021.
    _event_queue: queue.Queue para comunicação thread-safe
    entre OVERLAY_JS e Python collect_step.
  end note
}

package "P-Node-Recording: collect_step (atualizado)" as P_NodeRec {
  [CollectStep] as CollectStep
  note right of CollectStep
    Pull-based: page.evaluate("window.__tfEventQueue.splice(0)").
    Loop 300×100ms. Pacing via time.sleep() (síncrono) — BUG-021
    (wait_for_timeout criava coroutines asyncio órfãs).
    Verifica page.is_closed() no início de cada
    iteração (BUG-019). DebugLogger instrumentado a cada 10 iter.
    Transição page.on("close") → finish_requested=True.
  end note
}

DebugLogger --> Recorder : instrumenta browser_launch
DebugLogger --> CollectStep : instrumenta collect_step_poll
DebugLogger --> RecorderOverlay_BUG018 : instrumenta overlay_event
Recorder --> RecorderOverlay_BUG018 : injeta OVERLAY_JS + page.on("close")
RecorderOverlay_BUG018 --> CollectStep : window.__tfEventQueue (pull-based)
CollectStep --> Recorder : finish_requested → Recorder.finish()

@enduml
