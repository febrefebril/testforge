@startuml
title TestForge - Diagrama de Componentes da Arquitetura

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false

package "1. Interface e entrada" as P1 {
  [CLIRecord] as CLIRecord
  [InputValidator] as InputValidator
  [SettingsLoader] as SettingsLoader
  [WorkspaceManager] as WorkspaceManager
}

package "2. Camada de navegador e observabilidade" as P2 {
  [BrowserContextManager] as BrowserContextManager
  [PlaywrightAdapter] as PlaywrightAdapter
  [EventListener] as EventListener
  [TraceManager] as TraceManager
  [ScreenshotManager] as ScreenshotManager
  [NetworkObserver] as NetworkObserver
  [ConsoleObserver] as ConsoleObserver
  [FrameObserver] as FrameObserver
  [DialogObserver] as DialogObserver
}

package "3. Camada de gravação" as P3 {
  [SmartRecorder] as SmartRecorder
  [JSInjector] as JSInjector
  [RecorderOverlay] as RecorderOverlay
  [MutationObserverBridge] as MutationObserverBridge
  [DOMEventCollector] as DOMEventCollector
  [AssertHintCollector] as AssertHintCollector
  [CheckpointCollector] as CheckpointCollector
}

package "4. Camada de reconhecimento/fingerprint" as P4 {
  [FingerprintEngine] as FingerprintEngine
  [TechnologyDetector] as TechnologyDetector
  [JSFPrimeFacesDetector] as JSFPrimeFacesDetector
  [JQueryDetector] as JQueryDetector
  [AngularDetector] as AngularDetector
  [LegacyJSPDetector] as LegacyJSPDetector
  [IonicCordovaDetector] as IonicCordovaDetector
  [ComponentCataloger] as ComponentCataloger
  [DynamicIdDetector] as DynamicIdDetector
  [FrameShadowScanner] as FrameShadowScanner
}

package "5. Camada de evidências" as P5 {
