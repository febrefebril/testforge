@startuml curator-decision-tree
' TESTFORGE — Curator Decision Tree
' Artefato: curator-decision-tree.puml
' Base: Taxonomia implementável de casos conhecidos v1.0
' Objetivo: orientar a classificação, healing, fallback e estado final do Agente Curador.

skinparam backgroundColor #FFFFFF
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  FontColor #0F172A
  DiamondBackgroundColor #E0F2FE
  DiamondBorderColor #0369A1
  StartColor #16A34A
  EndColor #DC2626
}
skinparam note {
  BackgroundColor #FEF3C7
  BorderColor #D97706
  FontColor #111827
}
skinparam shadowing false

title TestForge — Árvore de Decisão do Curador

start
:Receber evento, falha, step ou pedido de curadoria;
:Coletar contexto mínimo;
note right
Contexto mínimo recomendado:
- snapshot DOM antes/depois
- locator original
- stack/fingerprint da tela
- frame/aba/contexto atual
- logs Playwright
- console/network quando disponíveis
- evidência visual/trace/HAR quando configurado
end note

if (Há evidência suficiente?) then (sim)
else (não)
  :Classificar como OBS-001;
  :Coletar screenshot, trace, console e/ou snapshot DOM;
  if (Evidência mínima obtida?) then (sim)
  else (não)
    :Resultado = UNRESOLVED;
    :Registrar ausência de evidência;
    stop
  endif
endif

:Identificar tecnologia predominante;
note right
Exemplos:
- JSF / PrimeFaces
- jQuery / jQuery UI
- Angular / SPA
- Web Components
- Browser security / cross-origin
- Recorder/TestForge
end note

if (Caso envolve risco técnico ou segurança?) then (sim)
  if (CAPTCHA/desafio humano?) then (sim)
    :Classificar LIM-001 ou INP-008;
    :Resultado = MANUAL_REQUIRED;
    :Registrar checkpoint manual;
    stop
  elseif (Cross-origin inacessível?) then (sim)
    :Classificar LIM-002 ou CTX-002;
    :Resultado = MANUAL_REQUIRED ou UNRESOLVED;
    :Não fabricar locator;
    stop
  elseif (Dado sensível mascarado?) then (sim)
    :Classificar LIM-003;
    :Aplicar mascaramento/tokenização;
    :Validar ausência de segredo em relatório;
    if (Dado protegido?) then (sim)
      :Resultado = RESOLVED;
    else (não)
      :Resultado = UNRESOLVED;
    endif
    stop
  elseif (Operação irreversível?) then (sim)
    :Classificar LIM-004;
    :Exigir confirmação/checkpoint explícito;
    :Resultado = MANUAL_REQUIRED;
    stop
  else (não)
    :Continuar classificação;
  endif
else (não)
endif

if (Falha é de seletor/locator?) then (sim)
  :Família = Seletores frágeis;
  if (ID JSF dinâmico?) then (sim)
    :Classificar SEL-001;
    :Aplicar semantic_locator_conversion;
  elseif (Índice de tabela/lista?) then (sim)
    :Classificar SEL-002 ou DOM-002;
    :Aplicar label_proximity por linha/chave;
  elseif (widgetVar PrimeFaces?) then (sim)
    :Classificar SEL-003;
    :Aplicar primefaces_registry_scan;
  elseif (XPath absoluto?) then (sim)
    :Classificar SEL-004;
    :Converter para locator semântico;
  elseif (classe volátil?) then (sim)
    :Classificar SEL-005;
    :Aplicar aria_role_strategy;
  elseif (texto duplicado?) then (sim)
    :Classificar SEL-009;
    :Desambiguar por escopo/container/role;
  else (outro)
    :Classificar melhor SEL-* compatível;
    :Aplicar fallback semântico;
  endif
elseif (Falha é de timing/assincronismo?) then (sim)
  :Família = Timing e assincronismo;
  if (Re-render JSF/AJAX?) then (sim)
    :Classificar TIM-001 ou DOM-003;
    :Aplicar network_idle_wait + dom_stabilization;
  elseif (ViewState hardcoded?) then (sim)
    :Classificar TIM-002;
    :Remover captura manual de ViewState;
  elseif (sleep fixo?) then (sim)
    :Classificar TIM-005;
    :Substituir por wait semântico;
  elseif (autocomplete/debounce?) then (sim)
    :Classificar TIM-006;
    :Aguardar lista/opção;
  else (outro)
    :Classificar TIM-* compatível;
    :Aplicar wait por condição observável;
  endif
elseif (Falha é de contexto/escopo?) then (sim)
  :Família = Contexto e escopo;
  if (iframe same-origin?) then (sim)
    :Classificar CTX-001;
    :Aplicar frame_reacquire/frameLocator;
  elseif (iframe cross-origin?) then (sim)
    :Classificar CTX-002/LIM-002;
    :Resultado = MANUAL_REQUIRED ou UNRESOLVED;
    :Não fabricar seletor;
    stop
  elseif (Shadow DOM aberto?) then (sim)
    :Classificar CTX-003;
    :Aplicar shadow_pierce;
  elseif (Shadow DOM fechado?) then (sim)
    :Classificar CTX-004;
    :Resultado = MANUAL_REQUIRED ou UNRESOLVED;
    stop
  elseif (popup/nova aba?) then (sim)
    :Classificar CTX-005;
    :Capturar popup/page e trocar contexto;
  else (outro)
    :Classificar CTX-* compatível;
  endif
elseif (Falha é de estado da aplicação?) then (sim)
  :Família = Estado da aplicação;
  if (Sessão expirada/login?) then (sim)
    :Classificar STA-001;
    :Aplicar re_auth_hook;
  elseif (Overlay bloqueia clique?) then (sim)
    :Classificar STA-002;
    :Aplicar overlay_dismiss ou aguardar sumir;
  elseif (Dialog nativo?) then (sim)
    :Classificar STA-004;
    :Instalar handler de dialog;
  elseif (Ambiente indisponível?) then (sim)
    :Classificar STA-006;
    :Não alterar script indevidamente;
    :Resultado = PARTIALLY_RESOLVED ou UNRESOLVED;
  else (outro)
    :Classificar STA-* compatível;
  endif
elseif (Falha envolve DOM dinâmico?) then (sim)
  :Família = DOM dinâmico;
  if (handle cacheado/detached?) then (sim)
    :Classificar DOM-001;
    :Rebuscar locator e evitar ElementHandle cacheado;
  elseif (lista virtualizada/lazy?) then (sim)
    :Classificar DOM-004 ou DOM-005;
    :Scroll/wait por conteúdo real;
  else (outro)
    :Classificar DOM-* compatível;
  endif
elseif (Falha envolve input especializado?) then (sim)
  :Família = Input e interação especializada;
  if (Upload?) then (sim)
    :Classificar INP-001/INP-002 ou FILE-001;
    :Aplicar upload_payload_binding e fixture versionada;
  elseif (Download?) then (sim)
    :Classificar INP-003/INP-004 ou FILE-*;
    :Aplicar download_event_capture;
  elseif (Drag-and-drop?) then (sim)
    :Classificar INP-005;
    :Simular interação semântica;
  elseif (Rich text editor?) then (sim)
    :Classificar INP-006;
    :Readquirir frame/contenteditable;
  else (outro)
    :Classificar INP-* compatível;
  endif
elseif (Falha envolve assert/validação?) then (sim)
  :Família = Asserts e validações;
  if (Assert antes da gravação?) then (sim)
    :Classificar AST-001;
    :Vincular ao plano inicial;
  elseif (Assert durante gravação?) then (sim)
    :Classificar AST-002;
    :Capturar via overlay;
  elseif (Assert depois da gravação?) then (sim)
    :Classificar AST-003;
    :Vincular ao step/tela correto;
  elseif (Assert ambíguo?) then (sim)
    :Classificar AST-008;
    :Resultado = MANUAL_REQUIRED;
    :Não inventar assert;
    stop
  else (outro)
    :Classificar AST-* compatível;
  endif
elseif (Caso é do recorder/overlay?) then (sim)
  :Família = Recorder, overlay e checkpoints manuais;
  if (Gravação incompleta?) then (sim)
    :Classificar REC-001;
    :Gerar script parcial com checkpoint;
    :Resultado = PARTIALLY_RESOLVED;
  elseif (Recon/fingerprint inicial?) then (sim)
    :Classificar REC-005;
    :Persistir mapa tecnológico;
  else (outro)
    :Classificar REC-* compatível;
  endif
else (não classificado)
  :Resultado = UNRESOLVED;
  :Registrar evidência e motivo;
  stop
endif

:Gerar patch candidato;
:Registrar ID taxonômico, estratégia, fallback e evidências;
:Executar validação controlada;

if (Validação passou?) then (sim)
  if (Requer promoção por estabilidade?) then (sim)
    :Aplicar política OBS-006;
    :Exigir rodadas limpas consecutivas definidas no projeto;
  else (não)
  endif
  :Resultado = RESOLVED;
  :Anexar diff, evidências e critério de sucesso;
  stop
else (não)
  :Aplicar próximo fallback disponível;
  if (Fallback passou?) then (sim)
    :Resultado = RESOLVED ou PARTIALLY_RESOLVED;
    :Registrar fallback utilizado;
    stop
  else (não)
    :Incrementar contador de rejeição por assinatura do patch;
    if (Limite de rejeições atingido?) then (sim)
      :Classificar OBS-005;
      :Resultado = UNRESOLVED;
      :Abrir pendência/checkpoint manual;
      stop
    else (não)
      :Gerar novo patch candidato;
      :Retornar à validação controlada;
    endif
  endif
endif

@enduml
