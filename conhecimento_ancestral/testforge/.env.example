# TestForge — LLM Healing (Azure OpenAI)
# Ativa LLM Healer real no pipeline de cura + Recipe Auto-Healing.
# Se estas vars não estiverem definidas, MockLLMHealer será usado (comportamento padrão).
# AZURE_OPENAI_KEY=sk-your-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_MODEL=gpt-4.1-mini
#
# O runner também aceita AZURE_OPENAI_API_KEY (nome alternativo).

# TestForge — Notificações (opcional)
# TF_NOTIFY_EMAIL_SMTP_HOST=smtp.example.com
# TF_NOTIFY_EMAIL_SMTP_PORT=587
# TF_NOTIFY_EMAIL_FROM=testforge@example.com
# TF_NOTIFY_EMAIL_TO=dev@example.com
# TF_NOTIFY_EMAIL_USERNAME=testforge@example.com
# TF_NOTIFY_EMAIL_PASSWORD=your-password
# TF_NOTIFY_TEAMS_WEBHOOK=https://your-org.webhook.office.com/...
