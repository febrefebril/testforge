+    sub = parser.add_subparsers(dest="command")
+    register(sub)
+    args = parser.parse_args(["run-incremental", str(tmp_path / "nao_existe.py")])
+    with pytest.raises(SystemExit) as exc:
+        cmd_run_incremental(args)
+    assert exc.value.code in (2, 3)
