    probable_causes: ["Elemento está sob shadow root aberto"]
    minimum_detection: ["Elemento está sob shadow root aberto"]
    primary_strategy: shadow_pierce
    fallback_strategies: [aria_role_strategy, text_content_match]
    expected_output: ["Locator compatível com Playwright"]
    success_criteria: ["Elemento localizado dentro do shadow DOM"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: CTX-004
    family: "Contexto e escopo"
    case: "Shadow DOM fechado"
    technologies: ["Web Components"]
    priority: P2
    observable_symptoms: ["Elemento inacessível"]
    probable_causes: ["Shadow root fechado"]
    minimum_detection: ["Shadow root fechado"]
    primary_strategy: manual_checkpoint
    fallback_strategies: [component_public_api, test_contract]
