    probable_causes: ["Frame detach/attach entre ações"]
    minimum_detection: ["Frame detach/attach entre ações"]
    primary_strategy: frame_reacquire
    fallback_strategies: [wait_for_frame_by_url, wait_for_frame_by_name]
    expected_output: ["Não cachear frame handle"]
    success_criteria: ["Ação ocorre após reacquisição"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: STA-001
