metadata:
  project: "TestForge / Agente Curador de Scripts"
  artifact: "Taxonomia implementável para detecção, classificação, healing e geração de testes"
  file: "taxonomy.cases.yaml"
  version: "1.0"
  base: "Capítulo 1 — Taxonomia de Falhas JSF, jQuery, AJAX e Frameworks Mobile"
  language: "pt-BR"

result_states:
  RESOLVED: "O curador classificou e aplicou uma correção validada."
  PARTIALLY_RESOLVED: "O curador aplicou correção, mas deixou ressalvas ou dependência manual."
  MANUAL_REQUIRED: "O caso exige intervenção humana explícita."
  UNRESOLVED: "O curador não conseguiu resolver com segurança."
  REJECTED: "A correção proposta foi rejeitada pelo validador."

priorities:
  P0: "Deve ser tratado no MVP; afeta diretamente a estabilidade básica dos scripts."
  P1: "Deve ser tratado após estabilização do núcleo; comum, mas pode ter workaround manual."
  P2: "Tratamento avançado, especializado ou dependente de contexto."

known_strategies:
  - label_proximity
  - text_content_match
  - aria_role_strategy
  - semantic_locator_conversion
  - primefaces_registry_scan
  - frame_reacquire
  - shadow_pierce
  - network_idle_wait
  - response_intercept
  - dom_stabilization
  - overlay_dismiss
  - re_auth_hook
  - llm_selector_inference
  - download_event_capture
  - upload_payload_binding
  - assert_overlay_capture
  - manual_checkpoint
  - wait_for_function
  - popup_capture
  - dialog_handler
  - precondition_validation
  - evidence_capture
  - patch_rejection_guard
  - flaky_validation_rounds
  - sensitive_data_masking
  - critical_operation_checkpoint

curator_decision_matrix:
  - order: 1
    action: "Identificar tecnologia predominante da tela ou componente."
  - order: 2
    action: "Identificar família da falha."
  - order: 3
    action: "Classificar pelo primeiro ID taxonômico compatível."
  - order: 4
    action: "Coletar evidências mínimas."
  - order: 5
    action: "Aplicar estratégia principal."
  - order: 6
    action: "Validar por execução controlada."
  - order: 7
    action: "Se falhar, aplicar fallback na ordem definida."
  - order: 8
    action: "Se houver risco técnico, segurança, CAPTCHA, cross-origin fechado ou assert ambíguo, marcar como MANUAL_REQUIRED."
  - order: 9
    action: "Se as tentativas forem rejeitadas pelo validador, marcar como UNRESOLVED."
  - order: 10
    action: "Registrar no relatório: ID, causa, estratégia, patch, evidência e resultado."

global_acceptance_criteria:
  - "Todo caso conhecido possuir ID estável."
  - "Toda alteração feita pelo curador referenciar um ID taxonômico."
  - "Todo ID P0 possuir pelo menos um teste automatizado do curador."
  - "Nenhum caso ambíguo gerar assert, locator ou patch inventado sem evidência."
  - "Uploads e downloads forem tratados como artefatos versionáveis, parametrizáveis e verificáveis."
  - "Asserts puderem ser informados antes, durante ou depois da gravação."
  - "Iframes cross-origin, CAPTCHA e operações irreversíveis forem tratados como checkpoints manuais ou casos não resolvidos com justificativa."
  - "O relatório final apresentar: falha, evidência, estratégia, patch, validação e estado."

families:
  - id: FAM-01
    name: "Seletores frágeis"
  - id: FAM-02
    name: "Timing e assincronismo"
  - id: FAM-03
    name: "Contexto e escopo"
  - id: FAM-04
    name: "Estado da aplicação"
  - id: FAM-05
    name: "DOM dinâmico"
  - id: FAM-06
    name: "Input e interação especializada"
  - id: FAM-07
    name: "Upload e download de arquivos"
  - id: FAM-08
    name: "Asserts e validações"
  - id: FAM-09
    name: "Recorder, overlay e checkpoints manuais"
  - id: FAM-10
    name: "Execução, evidência e observabilidade"
  - id: FAM-11
    name: "Limites técnicos e casos não automatizáveis com segurança"

cases:
  - id: SEL-001
    family: "Seletores frágeis"
    case: "ID JSF dinâmico"
    technologies: ["JSF", "PrimeFaces"]
    priority: P0
    observable_symptoms: ["Locator gravado quebra entre execuções"]
    probable_causes: ["ID gerado dinamicamente pelo JSF/PrimeFaces"]
    minimum_detection: ["ID contém padrão j_idt", "ID contém índice variável", "ID contém prefixos JSF encadeados"]
    primary_strategy: semantic_locator_conversion
    fallback_strategies: [label_proximity, text_content_match, aria_role_strategy, llm_selector_inference]
    expected_output: ["Locator semântico Playwright"]
    success_criteria: ["Elemento é localizado em 3 execuções limpas"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-002
    family: "Seletores frágeis"
    case: "ID com índice de tabela"
    technologies: ["JSF", "PrimeFaces"]
    priority: P0
    observable_symptoms: ["Ação aponta para linha errada"]
    probable_causes: ["Locator depende de índice numérico em tabela ou lista"]
    minimum_detection: ["Locator contém índice numérico em tabela/lista"]
    primary_strategy: label_proximity
    fallback_strategies: [text_content_match, table_cell_filter, llm_selector_inference]
    expected_output: ["Locator contextual por linha"]
    success_criteria: ["A ação ocorre na linha correta"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-003
    family: "Seletores frágeis"
    case: "widgetVar instável"
    technologies: ["PrimeFaces"]
    priority: P0
    observable_symptoms: ["Script depende de PF('x') que muda"]
    probable_causes: ["Uso direto de widgetVar como referência primária"]
    minimum_detection: ["Uso direto de PF(...)", "Widget sem evidência semântica"]
    primary_strategy: primefaces_registry_scan
    fallback_strategies: [aria_role_strategy, text_content_match, label_proximity]
    expected_output: ["Locator independente de widgetVar"]
    success_criteria: ["Elemento interage sem depender do nome do widget"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-004
    family: "Seletores frágeis"
    case: "XPath absoluto"
    technologies: ["Geral"]
    priority: P0
    observable_symptoms: ["Locator quebra com pequena mudança estrutural"]
    probable_causes: ["Caminho absoluto dependente da estrutura completa do DOM"]
    minimum_detection: ["XPath inicia em /html/body", "XPath usa cadeia longa de índices"]
    primary_strategy: semantic_locator_conversion
    fallback_strategies: [aria_role_strategy, text_content_match, label_proximity, stable_css]
    expected_output: ["Locator Playwright resiliente"]
    success_criteria: ["XPath absoluto removido"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-005
    family: "Seletores frágeis"
    case: "CSS baseado em classe volátil"
    technologies: ["Angular", "Frameworks modernos"]
    priority: P1
    observable_symptoms: ["Elemento não encontrado após build ou deploy"]
    probable_causes: ["Classe gerada, minificada, hash ou utilitária sem semântica"]
    minimum_detection: ["Classe parece hash", "Classe gerada/minificada", "Classe utilitária sem semântica"]
    primary_strategy: aria_role_strategy
    fallback_strategies: [data_testid, text_content_match, label_proximity]
    expected_output: ["Locator orientado a intenção"]
    success_criteria: ["Classe volátil não é seletor primário"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-006
    family: "Seletores frágeis"
    case: "Elemento sem ID"
    technologies: ["Angular", "Componentes modernos"]
    priority: P1
    observable_symptoms: ["Recorder gera locator genérico ou por índice"]
    probable_causes: ["Ausência de atributos identificadores estáveis"]
    minimum_detection: ["Ausência de id/name", "Presença de texto, role ou data-*"]
    primary_strategy: aria_role_strategy
    fallback_strategies: [text_content_match, data_testid, label_proximity]
    expected_output: ["Locator semântico"]
    success_criteria: ["Elemento localizado sem índice absoluto"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-007
    family: "Seletores frágeis"
    case: "Elemento fora do formulário"
    technologies: ["jQuery UI", "Dialogs"]
    priority: P0
    observable_symptoms: ["Botão em modal não é localizado no escopo esperado"]
    probable_causes: ["Elemento visual está fora do form/árvore original"]
    minimum_detection: ["Elemento visível está fora do form/árvore original"]
    primary_strategy: aria_role_strategy
    fallback_strategies: [dialog_role_scope, text_content_match, overlay_container_scope]
    expected_output: ["Locator no escopo real do DOM"]
    success_criteria: ["Clique ocorre no botão visível correto"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-008
    family: "Seletores frágeis"
    case: "Locator por posição"
    technologies: ["Geral"]
    priority: P1
    observable_symptoms: ["Ação quebra quando ordem visual muda"]
    probable_causes: ["Uso de índice posicional sem identidade semântica"]
    minimum_detection: ["Uso de .nth() sem justificativa"]
    primary_strategy: semantic_locator_conversion
    fallback_strategies: [text_filter, label_proximity, aria_role_strategy]
    expected_output: ["Locator contextual"]
    success_criteria: [".nth() removido ou justificado"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: SEL-009
    family: "Seletores frágeis"
    case: "Texto duplicado"
    technologies: ["Geral"]
    priority: P0
    observable_symptoms: ["Curador escolhe elemento errado com mesmo texto"]
    probable_causes: ["Múltiplos elementos correspondem ao mesmo texto"]
    minimum_detection: ["Múltiplos elementos correspondem ao mesmo texto"]
    primary_strategy: label_proximity
    fallback_strategies: [aria_role_strategy, container_scope, frame_scope, table_row_scope]
    expected_output: ["Locator desambiguado"]
    success_criteria: ["Match único ou escopo explícito"]
    result_states: {success: RESOLVED, failure: MANUAL_REQUIRED}

  - id: SEL-010
    family: "Seletores frágeis"
    case: "Label não associado via for"
    technologies: ["Legado", "JSF"]
    priority: P1
    observable_symptoms: ["Campo não é encontrado por label padrão"]
    probable_causes: ["Label visual próximo sem associação HTML"]
    minimum_detection: ["Label visual próximo", "Ausência de associação HTML via for"]
    primary_strategy: label_proximity
    fallback_strategies: [spatial_heuristic, placeholder, name_attribute]
    expected_output: ["Locator por proximidade"]
    success_criteria: ["Campo correto localizado"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: TIM-001
    family: "Timing e assincronismo"
    case: "Ação antes do re-render JSF"
    technologies: ["JSF AJAX"]
    priority: P0
    observable_symptoms: ["Clique ou assert ocorre antes da atualização"]
    probable_causes: ["Requisição AJAX seguida de DOM substituído"]
    minimum_detection: ["Requisição AJAX seguida de DOM substituído"]
    primary_strategy: network_idle_wait
    fallback_strategies: [dom_stabilization, wait_for_target_selector, response_intercept]
    expected_output: ["Wait semântico inserido"]
    success_criteria: ["Próxima ação encontra DOM atualizado"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: TIM-002
    family: "Timing e assincronismo"
    case: "ViewState inválido"
    technologies: ["JSF"]
    priority: P0
    observable_symptoms: ["Submissão falha após gravação"]
    probable_causes: ["Captura ou reutilização explícita de ViewState"]
    minimum_detection: ["Captura ou reutilização explícita de ViewState"]
    primary_strategy: avoid_hardcoded_viewstate
    fallback_strategies: [rerun_flow, wait_for_updated_form]
    expected_output: ["Script sem ViewState hardcoded"]
    success_criteria: ["Nenhum ViewState fixo no script"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: TIM-003
    family: "Timing e assincronismo"
    case: "Callback jQuery sem evento DOM claro"
    technologies: ["jQuery"]
    priority: P1
    observable_symptoms: ["Teste avança sem mudança visível imediata"]
    probable_causes: ["XHR/fetch finaliza, mas DOM muda depois"]
    minimum_detection: ["XHR/fetch finaliza", "Mudança DOM ocorre posteriormente"]
    primary_strategy: response_intercept
    fallback_strategies: [wait_for_function, wait_for_selector]
    expected_output: ["Wait baseado em resposta ou condição"]
    success_criteria: ["Condição de negócio observável é satisfeita"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: TIM-004
    family: "Timing e assincronismo"
    case: "Change detection assíncrono"
    technologies: ["Angular"]
    priority: P1
    observable_symptoms: ["Assert lê valor antigo"]
    probable_causes: ["Mudanças após microtasks/change detection"]
    minimum_detection: ["Presença de Angular", "Mudanças após microtasks"]
    primary_strategy: wait_for_function
    fallback_strategies: [wait_for_text_or_state, network_idle_wait]
    expected_output: ["Wait por condição da UI"]
    success_criteria: ["Assert passa sem timeout fixo"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: TIM-005
    family: "Timing e assincronismo"
    case: "waitForTimeout gravado"
    technologies: ["Geral"]
    priority: P0
    observable_symptoms: ["Script fica lento ou flaky"]
    probable_causes: ["Uso de sleeps fixos"]
    minimum_detection: ["Presença de sleeps fixos", "Uso de waitForTimeout"]
    primary_strategy: semantic_wait_replacement
    fallback_strategies: [dom_stabilization, network_idle_wait, wait_for_selector, response_intercept]
    expected_output: ["Timeout fixo removido"]
    success_criteria: ["Execução estável sem espera arbitrária"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: TIM-006
    family: "Timing e assincronismo"
    case: "Debounce em autocomplete"
    technologies: ["Geral", "jQuery", "Angular"]
    priority: P1
    observable_symptoms: ["Opções não aparecem no momento do clique"]
    probable_causes: ["Input seguido de lista assíncrona/debounce"]
