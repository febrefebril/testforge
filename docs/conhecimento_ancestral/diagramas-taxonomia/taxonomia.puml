    case: "Navegação parcial sem page load"
    technologies: ["SPA", "AJAX"]
    priority: P1
    observable_symptoms: ["waitForLoadState não resolve o estado real"]
    probable_causes: ["URL muda ou componente troca sem navegação completa"]
    minimum_detection: ["URL muda sem navegação completa", "Componente troca sem page load"]
    primary_strategy: wait_for_screen_marker
    fallback_strategies: [dom_stabilization, network_idle_wait]
    expected_output: ["Wait de tela pronta"]
    success_criteria: ["Próxima ação só ocorre com tela estável"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: CTX-001
    family: "Contexto e escopo"
    case: "Iframe same-origin"
