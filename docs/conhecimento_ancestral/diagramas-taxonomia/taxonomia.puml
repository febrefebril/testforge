    probable_causes: ["Elemento existe dentro de frame acessível"]
    minimum_detection: ["Elemento existe dentro de frame acessível"]
    primary_strategy: frame_reacquire
    fallback_strategies: [frame_by_url, frame_by_title, frame_by_name, frame_by_selector]
    expected_output: ["Locator usando frameLocator"]
    success_criteria: ["Ação ocorre dentro do frame correto"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: CTX-002
    family: "Contexto e escopo"
    case: "Iframe cross-origin"
    technologies: ["Geral", "Portais corporativos"]
    priority: P0
    observable_symptoms: ["Script não consegue injetar ou inspecionar DOM"]
    probable_causes: ["Frame bloqueia acesso por origem"]
    minimum_detection: ["Frame bloqueia acesso por origem", "Erro de cross-origin"]
    primary_strategy: manual_checkpoint
    fallback_strategies: [limited_playwright_interaction, external_contract]
    expected_output: ["Marcação MANUAL_REQUIRED ou estratégia segura"]
    success_criteria: ["Curador não fabrica seletor inacessível"]
    result_states: {success: MANUAL_REQUIRED, failure: UNRESOLVED}

  - id: CTX-003
    family: "Contexto e escopo"
    case: "Shadow DOM aberto"
