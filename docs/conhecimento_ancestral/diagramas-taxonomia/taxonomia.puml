  - id: STA-003
    family: "Estado da aplicação"
    case: "Dados sujos"
    technologies: ["Geral"]
    priority: P1
    observable_symptoms: ["Pré-condição não satisfeita"]
    probable_causes: ["Registro existente, duplicidade ou estado anterior"]
    minimum_detection: ["Tela mostra registro existente", "Tela mostra duplicidade", "Tela mostra estado anterior"]
    primary_strategy: precondition_validation
    fallback_strategies: [setup_teardown, dedicated_test_data]
    expected_output: ["Script com pré-condição explícita"]
    success_criteria: ["Teste não depende de estado residual"]
    result_states: {success: RESOLVED, failure: MANUAL_REQUIRED}

  - id: STA-004
    family: "Estado da aplicação"
    case: "Alert/confirm/prompt nativo"
    technologies: ["Geral"]
    priority: P0
    observable_symptoms: ["Execução trava aguardando diálogo"]
    probable_causes: ["Evento dialog emitido sem handler"]
    minimum_detection: ["Evento dialog emitido"]
    primary_strategy: dialog_handler
    fallback_strategies: [configured_accept_policy, configured_dismiss_policy]
    expected_output: ["Tratamento explícito de dialog"]
    success_criteria: ["Execução não trava"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: STA-005
    family: "Estado da aplicação"
    case: "Permissão insuficiente"
    technologies: ["Geral"]
    priority: P1
    observable_symptoms: ["Botão ausente ou acesso negado"]
    probable_causes: ["Perfil sem autorização necessária"]
    minimum_detection: ["Texto/HTTP/URL indica restrição"]
    primary_strategy: environment_profile_classification
    fallback_strategies: [manual_checkpoint, justified_skip]
    expected_output: ["MANUAL_REQUIRED ou UNRESOLVED"]
    success_criteria: ["Falha classificada corretamente"]
    result_states: {success: MANUAL_REQUIRED, failure: UNRESOLVED}

  - id: STA-006
    family: "Estado da aplicação"
    case: "Ambiente indisponível/intermitente"
    technologies: ["Geral"]
    priority: P1
    observable_symptoms: ["Erro HTTP, timeout global, tela de indisponibilidade"]
    probable_causes: ["Indisponibilidade de ambiente, proxy, DNS ou serviço"]
    minimum_detection: ["HTTP 5xx", "DNS", "Proxy", "Tela de erro"]
    primary_strategy: environment_failure_classification
    fallback_strategies: [controlled_retry, evidence_capture]
    expected_output: ["Relatório de ambiente"]
    success_criteria: ["Curador não altera script indevidamente"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

  - id: DOM-001
    family: "DOM dinâmico"
