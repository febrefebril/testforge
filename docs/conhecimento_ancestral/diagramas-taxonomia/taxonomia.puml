    primary_strategy: wait_for_option_list
    fallback_strategies: [response_intercept, wait_for_function]
    expected_output: ["Seleção robusta"]
    success_criteria: ["Opção correta selecionada"]
    result_states: {success: RESOLVED, failure: UNRESOLVED}

