{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/project-context.md"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx", "-y", "@modelcontextprotocol/server-filesystem",
        "/home/febre/Projetos/testforge",
        "/home/febre/Projetos"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "env": {
        "MEMORY_FILE_PATH": "/home/febre/Projetos/testforge/.opencode/memory.json"
      }
    }
  }
}
