@startuml
title TestForge v1 — C4 Context Diagram

!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

Person(qa, "QA Engineer", "Grava fluxos de teste em aplicacoes web e recebe scripts executaveis com self-healing.")

System(testforge, "TestForge", "Plataforma de gravacao inteligente de testes E2E com self-healing deterministico.")

System_Ext(web_app, "Aplicacao Web Alvo", "Aplicacao enterprise sob teste (PrimeFaces, Angular, JSF, jQuery UI, Kendo).")

System_Ext(llm, "LLM Gateway (Opcional)", "Azure OpenAI / API compativel. Usado apenas como curador, off critical path.")

System_Ext(ci, "Pipeline CI/CD", "GitHub Actions / Azure DevOps. Executa scripts gerados no pipeline.")

Rel(qa, testforge, "Grava fluxo de teste", "Playwright nativo (sem extensao)")
Rel(testforge, web_app, "Instrumenta e interage", "HTTP/HTTPS, pointerup, input, keydown")
Rel(testforge, ci, "Exporta script Playwright", "Python script + data.json")
Rel(testforge, llm, "Consulta apenas quando deterministico falha", "Prompt estruturado, nao aberto")
Rel(qa, ci, "Dispara pipeline", "Commit/push")

@enduml
